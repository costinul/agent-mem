{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "API: agent-mem server",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/api",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env"
        },
        {
            "name": "Eval: LoCoMo (1 conversation)",
            "type": "debugpy",
            "request": "launch",
            "module": "locomo.run",
            "cwd": "${workspaceFolder}/eval",
            "args": ["--limit", "1", "--out", "smoke_results.json"],
            "console": "integratedTerminal",
            "justMyCode": false,
            "envFile": "${workspaceFolder}/.env"
        }
    ]
}
